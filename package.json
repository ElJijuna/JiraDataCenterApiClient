{
  "name": "jira-datacenter-api-client",
  "version": "1.1.0",
  "description": "TypeScript client for Jira Data Center REST API",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "scripts": {
    "build": "tsup",
    "docs": "typedoc",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "check": "npm run lint && npm run format:check"
  },
  "keywords": [
    "jira",
    "jira-server",
    "jira-data-center",
    "api-client",
    "rest"
  ],
  "license": "MIT",
  "homepage": "https://eljijuna.github.io/JiraDataCenterApiClient",
  "repository": {
    "type": "git",
    "url": "https://github.com/ElJijuna/JiraDataCenterApiClient.git"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.5.2",
    "eslint": "^10.7.0",
    "jest": "^29.7.0",
    "semantic-release": "^24.2.3",
    "super-configs": "^1.18.0",
    "ts-jest": "^29.3.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.4.0",
    "typedoc": "^0.28.20",
    "typescript": "^5.8.3"
  },
  "author": "pilmee <pilmee@gmail.com> (https://github.com/ElJijuna)"
}
